<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>


<VBox prefHeight="700.0" prefWidth="1000.0" spacing="8.0" stylesheets="@../css/bootstrap3.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <HBox VBox.vgrow="ALWAYS">
         <children>
            <VBox maxWidth="216.0" minWidth="216.0" prefWidth="216.0" spacing="4.0">
               <children>
                  <Label text="Printer">
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                  </Label>
                  <ComboBox fx:id="cbPrinters" prefWidth="200.0" promptText="Select Printer" />
                  <Label text="Paper Size">
                     <VBox.margin>
                        <Insets top="8.0" />
                     </VBox.margin>
                  </Label>
                  <ComboBox fx:id="cbPapers" prefWidth="200.0" promptText="Select Paper Size" />
                  <Label text="No. of Copies">
                     <VBox.margin>
                        <Insets top="8.0" />
                     </VBox.margin>
                  </Label>
                  <TextField fx:id="tfCopies" maxWidth="200.0" prefWidth="200.0" text="1" />
               </children>
            </VBox>
            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label text="Print Preview" />
                  <ScrollPane fitToWidth="true" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                     <content>
                        <VBox fx:id="pages" prefWidth="100.0" spacing="16.0" />
                     </content>
                  </ScrollPane>
                  <HBox alignment="CENTER_LEFT">
                     <children>
                        <Label text="Zoom" />
                        <Label text="(50%)" />
                        <Slider fx:id="zoomSlider" disable="true" max="1.0" prefWidth="500.0" value="1.0" />
                        <Label text="100%" />
                     </children>
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                     <padding>
                        <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                     </padding>
                  </HBox>
               </children>
            </VBox>
         </children>
      </HBox>
      <HBox alignment="CENTER_LEFT" prefWidth="200.0" spacing="5.0">
         <children>
            <ProgressBar fx:id="progressBar" prefWidth="500.0" visible="false" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnPrint" defaultButton="true" mnemonicParsing="false" styleClass="primary" text="Print" />
            <Button fx:id="btnCancel" cancelButton="true" mnemonicParsing="false" text="Close" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
   </padding>
</VBox>
