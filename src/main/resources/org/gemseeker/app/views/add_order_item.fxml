<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>


<VBox spacing="4.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1">
   <stylesheets>
      <URL value="@css/bootstrap3.css" />
      <URL value="@css/styles.css" />
   </stylesheets>
   <children>
      <Label styleClass="form-title" text="Order Item" />
      <HBox spacing="8.0">
         <children>
            <VBox>
               <children>
                  <Label styleClass="form-label" text="Product" />
                  <ComboBox fx:id="cbProducts" prefWidth="150.0" promptText="Select Product" styleClass="form-combo-box" />
               </children>
            </VBox>
            <VBox>
               <children>
                  <Label styleClass="form-label" text="Discount (%)" />
                  <TextField fx:id="tfDiscount" prefWidth="100.0" text="0" />
               </children>
            </VBox>
            <VBox>
               <children>
                  <Label styleClass="form-label" text="Price After/Unit" />
                  <TextField fx:id="tfPriceAfter" editable="false" prefWidth="100.0" />
               </children>
            </VBox>
            <VBox>
               <children>
                  <Label styleClass="form-label" text="Qty" />
                  <TextField fx:id="tfQuantity" prefWidth="60.0" text="1" />
               </children>
            </VBox>
            <VBox>
               <children>
                  <Label styleClass="form-label" text="Total Price" />
                  <TextField fx:id="tfTotal" editable="false" prefWidth="100.0" />
               </children>
            </VBox>
         </children>
      </HBox>
      <ProgressBar fx:id="progressBar" prefWidth="540.0" visible="false">
         <VBox.margin>
            <Insets />
         </VBox.margin>
      </ProgressBar>
      <HBox alignment="CENTER_RIGHT" prefWidth="200.0" spacing="5.0">
         <children>
            <Button fx:id="btnSave" defaultButton="true" mnemonicParsing="false" prefWidth="120.0" styleClass="primary" text="Add Item" />
            <Button fx:id="btnCancel" cancelButton="true" mnemonicParsing="false" prefWidth="120.0" text="Cancel" />
         </children>
         <VBox.margin>
            <Insets top="8.0" />
         </VBox.margin>
      </HBox>
   </children>
   <padding>
      <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
   </padding>
</VBox>
