<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="4.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1">
   <stylesheets>
      <URL value="@css/bootstrap3.css" />
      <URL value="@css/styles.css" />
   </stylesheets>
   <children>
      <Label styleClass="form-title" text="Order Item" />
      <HBox spacing="16.0" VBox.vgrow="ALWAYS">
         <children>
            <VBox>
               <children>
                  <Label styleClass="form-label" text="Products" />
                  <ListView fx:id="productsList" prefHeight="300.0" prefWidth="200.0" />
               </children>
            </VBox>
            <VBox spacing="4.0">
               <children>
                  <HBox spacing="8.0">
                     <children>
                        <VBox />
                     </children>
                  </HBox>
                  <VBox spacing="4.0">
                     <children>
                        <HBox>
                           <children>
                              <Label prefWidth="110.0" styleClass="form-label" text="Supplier:" />
                              <Label fx:id="lblSupplier" styleClass="form-label" text="No Product Selected" />
                           </children>
                           <VBox.margin>
                              <Insets top="16.0" />
                           </VBox.margin>
                        </HBox>
                        <HBox>
                           <children>
                              <Label prefWidth="110.0" styleClass="form-label" text="In Stock:" />
                              <Label fx:id="lblStock" text="0">
                                 <styleClass>
                                    <String fx:value="form-label" />
                                    <String fx:value="text-bold" />
                                 </styleClass>
                              </Label>
                           </children>
                        </HBox>
                        <HBox>
                           <children>
                              <Label prefWidth="110.0" styleClass="form-label" text="Retail Price" />
                              <Label fx:id="lblPrice" text="0">
                                 <styleClass>
                                    <String fx:value="form-label" />
                                    <String fx:value="text-bold" />
                                 </styleClass>
                              </Label>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  <Region prefWidth="200.0" VBox.vgrow="ALWAYS" />
                  <HBox spacing="8.0">
                     <children>
                        <VBox HBox.hgrow="ALWAYS">
                           <children>
                              <Label styleClass="form-label" text="Quantity" />
                              <TextField fx:id="tfQuantity" prefWidth="100.0" text="1" />
                           </children>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS">
                           <children>
                              <Label styleClass="form-label" text="Total Price" />
                              <TextField fx:id="tfTotal" editable="false" prefWidth="100.0" />
                           </children>
                        </VBox>
                     </children>
                     <VBox.margin>
                        <Insets top="16.0" />
                     </VBox.margin>
                  </HBox>
               </children>
            </VBox>
         </children>
      </HBox>
      <ProgressBar fx:id="progressBar" prefWidth="250.0" visible="false">
         <VBox.margin>
            <Insets />
         </VBox.margin>
      </ProgressBar>
      <HBox alignment="CENTER_RIGHT" spacing="5.0">
         <children>
            <Button fx:id="btnSave" defaultButton="true" disable="true" mnemonicParsing="false" prefWidth="120.0" styleClass="primary" text="Add Item" />
            <Button fx:id="btnCancel" cancelButton="true" mnemonicParsing="false" prefWidth="120.0" text="Cancel" />
         </children>
         <VBox.margin>
            <Insets top="8.0" />
         </VBox.margin>
      </HBox>
   </children>
   <padding>
      <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
   </padding>
</VBox>
