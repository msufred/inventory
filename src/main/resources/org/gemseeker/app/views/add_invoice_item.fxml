<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="434.0" prefWidth="600.0" spacing="4.0" stylesheets="@css/styles.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label styleClass="form-title" text="Invoice Item" />
      <HBox spacing="16.0" VBox.vgrow="ALWAYS">
         <children>
            <VBox prefHeight="200.0" prefWidth="300.0" spacing="4.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="form-label" text="Select Product" />
                  <TableView fx:id="productsTable" prefHeight="300.0" prefWidth="400.0" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colName" prefWidth="100.0" text="Product Name" />
                      <TableColumn fx:id="colSupplier" prefWidth="75.0" text="Supplier" />
                        <TableColumn fx:id="colStock" prefWidth="75.0" text="In Stock" />
                        <TableColumn fx:id="colRetailPrice" prefWidth="75.0" text="Retail Price" />
                    </columns>
                  </TableView>
               </children>
            </VBox>
            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
               <children>
                  <VBox>
                     <children>
                        <Label styleClass="form-label" text="Discount (%)" />
                        <TextField fx:id="tfDiscount" prefWidth="176.0" text="0" />
                     </children>
                     <VBox.margin>
                        <Insets top="32.0" />
                     </VBox.margin>
                  </VBox>
                  <VBox>
                     <children>
                        <Label styleClass="form-label" text="Discounted Price" />
                        <TextField fx:id="tfDiscountedPrice" editable="false" prefWidth="176.0" text="0.00" />
                     </children>
                  </VBox>
                  <VBox>
                     <children>
                        <Label styleClass="form-label" text="Quantity" />
                        <TextField fx:id="tfQuantity" prefWidth="176.0" text="1" />
                     </children>
                  </VBox>
                  <VBox>
                     <children>
                        <Label styleClass="form-label" text="Total Price" />
                        <TextField fx:id="tfTotal" editable="false" prefWidth="176.0" text="0.00" />
                     </children>
                  </VBox>
               </children>
            </VBox>
         </children>
      </HBox>
      <ProgressBar fx:id="progressBar" prefWidth="600.0" visible="false">
         <VBox.margin>
            <Insets top="16.0" />
         </VBox.margin>
      </ProgressBar>
      <HBox alignment="CENTER_RIGHT" prefWidth="200.0" spacing="5.0">
         <children>
            <Button fx:id="btnSave" defaultButton="true" mnemonicParsing="false" styleClass="primary" text="Add Item" />
            <Button fx:id="btnCancel" cancelButton="true" mnemonicParsing="false" text="Cancel" />
         </children>
         <VBox.margin>
            <Insets top="8.0" />
         </VBox.margin>
      </HBox>
   </children>
   <padding>
      <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
   </padding>
</VBox>
