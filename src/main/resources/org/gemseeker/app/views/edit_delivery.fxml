<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="600.0" spacing="4.0" stylesheets="@css/styles.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label styleClass="form-title" text="Delivery Invoice" />
      <HBox alignment="CENTER_LEFT" spacing="8.0">
         <children>
            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label text="Invoice No" />
                  <TextField fx:id="tfInvoiceId" editable="false" prefWidth="100.0" />
               </children>
            </VBox>
            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label text="Shipper" />
                  <TextField fx:id="tfShipper" editable="false" prefWidth="250.0" />
               </children>
            </VBox>
            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label text="Invoice Date" />
                  <DatePicker fx:id="datePicker" prefWidth="150.0" />
               </children>
            </VBox>
         </children>
      </HBox>
      <HBox alignment="CENTER_LEFT">
         <children>
            <Label prefWidth="120.0" text="Customer Name" />
            <TextField fx:id="tfCustomer" HBox.hgrow="ALWAYS" />
         </children>
         <VBox.margin>
            <Insets top="16.0" />
         </VBox.margin>
      </HBox>
      <HBox alignment="CENTER_LEFT">
         <children>
            <Label prefWidth="120.0" text="Address" />
            <TextField fx:id="tfAddress" HBox.hgrow="ALWAYS" />
         </children>
      </HBox>
      <HBox alignment="CENTER_LEFT">
         <children>
            <Label prefWidth="120.0" text="Payment Type" />
            <ComboBox fx:id="cbPaymentTypes" prefWidth="200.0" promptText="Payment Type" />
         </children>
      </HBox>
      <Label text="Invoice Items">
         <VBox.margin>
            <Insets top="16.0" />
         </VBox.margin>
         <styleClass>
            <String fx:value="form-label" />
            <String fx:value="text-bold" />
            <String fx:value="text-big" />
         </styleClass>
      </Label>
      <HBox alignment="CENTER_LEFT" spacing="4.0">
         <children>
            <Button fx:id="btnAdd" mnemonicParsing="false" styleClass="primary" text="Add Item" />
            <Button fx:id="btnEdit" mnemonicParsing="false" text="Edit" />
            <Button fx:id="btnRemove" mnemonicParsing="false" text="Remove" />
            <Region HBox.hgrow="ALWAYS" />
            <Label text="Total" />
            <Label fx:id="lblTotal" text="P 0.00">
               <styleClass>
                  <String fx:value="form-label" />
                  <String fx:value="text-bold" />
                  <String fx:value="text-big" />
               </styleClass>
            </Label>
         </children>
      </HBox>
      <TableView fx:id="itemsTable" prefHeight="200.0" prefWidth="200.0">
        <columns>
          <TableColumn fx:id="colName" prefWidth="75.0" text="Name" />
          <TableColumn fx:id="colUnit" prefWidth="75.0" styleClass="table-cell-center-align" text="Unit" />
            <TableColumn fx:id="colPriceBefore" prefWidth="75.0" styleClass="table-cell-right-align" text="Unit Price" />
            <TableColumn prefWidth="75.0" text="Discount">
               <columns>
                  <TableColumn fx:id="colDiscount" prefWidth="101.0" styleClass="table-cell-center-align" text="(per Unit)" />
               </columns>
            </TableColumn>
            <TableColumn prefWidth="100.0" text="Discounted Price">
               <columns>
                  <TableColumn fx:id="colPriceAfter" prefWidth="100.0" styleClass="table-cell-right-align" text="(per Unit)" />
               </columns>
            </TableColumn>
            <TableColumn fx:id="colQuantity" prefWidth="75.0" styleClass="table-cell-center-align" text="Qty" />
            <TableColumn fx:id="colTotal" prefWidth="77.0" styleClass="table-cell-right-align" text="Total" />
        </columns>
      </TableView>
      <ProgressBar fx:id="progressBar" prefWidth="600.0" visible="false">
         <VBox.margin>
            <Insets />
         </VBox.margin>
      </ProgressBar>
      <HBox alignment="CENTER_RIGHT" prefWidth="200.0" spacing="5.0">
         <children>
            <Button fx:id="btnSave" defaultButton="true" mnemonicParsing="false" styleClass="primary" text="Save" />
            <Button fx:id="btnCancel" cancelButton="true" mnemonicParsing="false" text="Cancel" />
         </children>
         <VBox.margin>
            <Insets top="8.0" />
         </VBox.margin>
      </HBox>
   </children>
   <padding>
      <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
   </padding>
</VBox>
