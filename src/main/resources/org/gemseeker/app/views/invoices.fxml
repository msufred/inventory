<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>


<VBox prefHeight="500.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <HBox alignment="CENTER_LEFT" prefWidth="200.0" spacing="4.0">
         <children>
            <Button mnemonicParsing="false" styleClass="primary" text="Add Invoice" />
            <ToggleButton mnemonicParsing="false" selected="true" text="Hide Details" />
         </children>
         <padding>
            <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
         </padding>
      </HBox>
      <SplitPane dividerPositions="0.6" VBox.vgrow="ALWAYS">
         <items>
            <TableView prefHeight="200.0" prefWidth="200.0">
              <columns>
                <TableColumn prefWidth="75.0" text="Date" />
                <TableColumn prefWidth="75.0" text="Invoice No" />
                  <TableColumn prefWidth="150.0" text="Customer" />
                  <TableColumn prefWidth="75.0" text="Status" />
                  <TableColumn prefWidth="100.0" text="Total Amount" />
              </columns>
            </TableView>
            <VBox>
               <children>
                  <TableView prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn prefWidth="116.0" text="Item" />
                      <TableColumn prefWidth="70.0" text="Quantity" />
                        <TableColumn prefWidth="75.0" text="Total" />
                    </columns>
                  </TableView>
                  <HBox alignment="CENTER_RIGHT" prefWidth="200.0" spacing="8.0">
                     <children>
                        <Label styleClass="text-big" text="Total" />
                        <Label text="P 0.00">
                           <styleClass>
                              <String fx:value="text-big" />
                              <String fx:value="text-bold" />
                           </styleClass>
                        </Label>
                     </children>
                     <padding>
                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                     </padding>
                  </HBox>
               </children>
            </VBox>
         </items>
      </SplitPane>
   </children>
   <stylesheets>
      <URL value="@css/bootstrap3.css" />
      <URL value="@css/styles.css" />
   </stylesheets>
</VBox>
