<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="600.0" spacing="4.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1">
   <stylesheets>
      <URL value="@css/bootstrap3.css" />
      <URL value="@css/styles.css" />
   </stylesheets>
   <children>
      <Label styleClass="form-title" text="New Purchase" />
      <HBox spacing="4.0">
         <children>
            <VBox>
               <children>
                  <Label styleClass="form-label" text="Invoice No" />
                  <TextField fx:id="tfNo" prefWidth="100.0" promptText="Invoice No" styleClass="form-text-field" />
               </children>
            </VBox>
            <VBox HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="form-label" text="Supplier Name" />
                  <ComboBox fx:id="cbSuppliers" editable="true" prefWidth="300.0" promptText="Select or Enter Supplier" styleClass="form-combo-box" />
               </children>
            </VBox>
            <VBox>
               <children>
                  <Label styleClass="form-label" text="Purchase Date" />
                  <DatePicker fx:id="datePicker" editable="false" />
               </children>
            </VBox>
         </children>
      </HBox>
      <HBox alignment="CENTER_LEFT" spacing="4.0">
         <children>
            <Button fx:id="btnAdd" mnemonicParsing="false" styleClass="primary" text="Add Product" />
            <Button fx:id="btnEdit" disable="true" mnemonicParsing="false" text="Edit" />
            <Button fx:id="btnRemove" disable="true" mnemonicParsing="false" text="Remove" />
            <Region HBox.hgrow="ALWAYS" />
            <Label styleClass="form-label" text="Total" />
            <Label fx:id="lblTotal" text="P 0.00">
               <styleClass>
                  <String fx:value="form-label" />
                  <String fx:value="text-bold" />
                  <String fx:value="text-big" />
               </styleClass>
            </Label>
         </children>
         <VBox.margin>
            <Insets top="16.0" />
         </VBox.margin>
      </HBox>
      <TableView fx:id="itemsTable" prefHeight="200.0" prefWidth="200.0">
        <columns>
          <TableColumn fx:id="colName" prefWidth="75.0" text="Item" />
            <TableColumn fx:id="colSku" prefWidth="75.0" text="SKU" />
          <TableColumn fx:id="colUnit" prefWidth="75.0" styleClass="table-cell-center-align" text="Unit" />
            <TableColumn fx:id="colPrice" prefWidth="75.0" styleClass="table-cell-right-align" text="Unit Price" />
            <TableColumn fx:id="colRetailPrice" prefWidth="75.0" styleClass="table-cell-right-align" text="Retail Price" />
            <TableColumn fx:id="colQuantity" prefWidth="50.0" styleClass="table-cell-center-align" text="Quantity" />
            <TableColumn fx:id="colTotal" prefWidth="77.0" styleClass="table-cell-right-align" text="Total" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <ProgressBar fx:id="progressBar" prefWidth="600.0" visible="false">
         <VBox.margin>
            <Insets />
         </VBox.margin>
      </ProgressBar>
      <HBox alignment="CENTER_RIGHT" prefWidth="200.0" spacing="5.0">
         <children>
            <Button fx:id="btnSave" defaultButton="true" mnemonicParsing="false" prefWidth="120.0" styleClass="primary" text="Save" />
            <Button fx:id="btnCancel" cancelButton="true" mnemonicParsing="false" prefWidth="120.0" text="Cancel" />
         </children>
         <VBox.margin>
            <Insets top="8.0" />
         </VBox.margin>
      </HBox>
   </children>
   <padding>
      <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
   </padding>
</VBox>
