<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="400.0" spacing="4.0" stylesheets="@css/styles.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label text="Edit Order Item">
         <styleClass>
            <String fx:value="text-big" />
            <String fx:value="text-bold" />
         </styleClass></Label>
      <Label styleClass="form-label" text="Product Name">
         <VBox.margin>
            <Insets />
         </VBox.margin>
      </Label>
      <TextField fx:id="tfName" editable="false" promptText="Product Name" styleClass="form-text-field" />
      <Label styleClass="form-label" text="Supplier" />
      <TextField fx:id="tfSupplier" editable="false" promptText="Supplier Name" styleClass="form-text-field" />
      <HBox spacing="8.0">
         <children>
            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="form-label" text="In Stock" />
                  <TextField fx:id="tfInStock" editable="false" prefWidth="200.0" styleClass="form-text-field" text="0" />
               </children>
            </VBox>
            <VBox spacing="4.0">
               <children>
                  <Label styleClass="form-label" text="Retail Price (PHP)" />
                  <TextField fx:id="tfRetailPrice" editable="false" prefWidth="200.0" styleClass="form-text-field" text="0" />
               </children>
            </VBox>
         </children>
      </HBox>
      <HBox spacing="8.0">
         <children>
            <VBox spacing="4.0">
               <children>
                  <Label styleClass="form-label" text="Quantity" />
                  <TextField fx:id="tfQuantity" promptText="Initial Stock Quantity" styleClass="form-text-field" text="0" />
               </children>
            </VBox>
            <VBox spacing="4.0">
               <children>
                  <Label styleClass="form-label" text="Total Amount" />
                  <TextField fx:id="tfTotal" editable="false" promptText="Initial Stock Quantity" styleClass="form-text-field" text="0" />
               </children>
            </VBox>
         </children>
      </HBox>
      <ProgressBar fx:id="progressBar" prefWidth="400.0" visible="false">
         <VBox.margin>
            <Insets top="16.0" />
         </VBox.margin>
      </ProgressBar>
      <HBox alignment="CENTER_RIGHT" prefWidth="200.0" spacing="5.0">
         <children>
            <Button fx:id="btnSave" defaultButton="true" mnemonicParsing="false" styleClass="primary" text="Update Product" />
            <Button fx:id="btnCancel" cancelButton="true" mnemonicParsing="false" text="Cancel" />
         </children>
         <VBox.margin>
            <Insets top="8.0" />
         </VBox.margin>
      </HBox>
   </children>
   <padding>
      <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
   </padding>
</VBox>
