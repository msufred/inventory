<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="500.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <HBox alignment="CENTER_LEFT" prefWidth="200.0" spacing="4.0">
         <children>
            <Button fx:id="btnAdd" mnemonicParsing="false" styleClass="primary" text="Add Order" />
            <Button fx:id="btnPrintList" mnemonicParsing="false" text="Print List" />
         </children>
         <padding>
            <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
         </padding>
      </HBox>
      <SplitPane fx:id="splitPane" dividerPositions="0.4" VBox.vgrow="ALWAYS">
         <items>
            <TableView fx:id="ordersTable" prefHeight="200.0" prefWidth="200.0">
              <columns>
                <TableColumn fx:id="colDate" prefWidth="100.0" styleClass="table-cell-center-align" text="Date" />
                <TableColumn fx:id="colShipperName" prefWidth="200.0" styleClass="table-cell-center-align" text="Shipper Name" />
                  <TableColumn fx:id="colTotal" prefWidth="100.0" styleClass="table-cell-right-align" text="Total Amount" />
              </columns>
            </TableView>
            <VBox>
               <children>
                  <Label styleClass="text-bold" text="Order Details">
                     <VBox.margin>
                        <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                     </VBox.margin>
                  </Label>
                  <TableView fx:id="orderItemsTable" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colItemName" prefWidth="75.0" text="Item" />
                        <TableColumn fx:id="colItemSupplier" prefWidth="75.0" text="Supplier" />
                        <TableColumn fx:id="colItemUnit" prefWidth="40.0" styleClass="table-cell-center-align" text="Unit" />
                        <TableColumn fx:id="colItemUnitPrice" prefWidth="75.0" styleClass="table-cell-right-align" text="Unit Price" />
                      <TableColumn fx:id="colItemQuantity" prefWidth="50.0" styleClass="table-cell-center-align" text="Qty" />
                        <TableColumn fx:id="colItemTotal" prefWidth="75.0" styleClass="table-cell-right-align" text="Total" />
                        <TableColumn maxWidth="20.0" minWidth="20.0" prefWidth="20.0" />
                        <TableColumn prefWidth="100.0" text="Shipper Inventory">
                           <columns>
                              <TableColumn fx:id="colItemInStock" prefWidth="70.0" text="In Stock">
                                 <styleClass>
                                    <String fx:value="table-cell-center-align" />
                                    <String fx:value="table-cell-text-green" />
                                 </styleClass>
                              </TableColumn>
                              <TableColumn fx:id="colItemQuantityOut" prefWidth="70.0" text="Out">
                                 <styleClass>
                                    <String fx:value="table-cell-center-align" />
                                    <String fx:value="table-cell-text-green" />
                                 </styleClass>
                              </TableColumn>
                              <TableColumn fx:id="colItemTotalOut" prefWidth="70.0" text="Sales">
                                 <styleClass>
                                    <String fx:value="table-cell-right-align" />
                                    <String fx:value="table-cell-text-green" />
                                 </styleClass>
                              </TableColumn>
                           </columns>
                        </TableColumn>
                    </columns>
                  </TableView>
               </children>
            </VBox>
         </items>
      </SplitPane>
   </children>
   <stylesheets>
      <URL value="@css/bootstrap3.css" />
      <URL value="@css/styles.css" />
   </stylesheets>
</VBox>
