<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="400.0" prefWidth="800.0" stylesheets="@css/styles.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <HBox prefWidth="200.0" spacing="4.0">
         <children>
            <Button fx:id="btnAddTruck" mnemonicParsing="false" text="Add Truck" />
         </children>
         <padding>
            <Insets bottom="4.0" left="4.0" right="4.0" top="4.0" />
         </padding>
      </HBox>
      <SplitPane dividerPositions="0.25" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
         <items>
            <ListView fx:id="trucksList" prefHeight="200.0" prefWidth="200.0" />
            <TabPane prefHeight="200.0" prefWidth="200.0" tabClosingPolicy="UNAVAILABLE">
              <tabs>
                <Tab text="Orders">
                     <content>
                        <VBox>
                           <children>
                              <HBox alignment="CENTER_LEFT" prefWidth="200.0" spacing="4.0">
                                 <children>
                                    <Button fx:id="btnAddOrder" mnemonicParsing="false" />
                                    <Button fx:id="btnEditOrder" mnemonicParsing="false" />
                                    <Button fx:id="btnDeleteOrder" mnemonicParsing="false" />
                                    <Label text="Orders from">
                                       <HBox.margin>
                                          <Insets left="16.0" />
                                       </HBox.margin>
                                    </Label>
                                    <DatePicker />
                                    <Label text="to" />
                                    <DatePicker />
                                 </children>
                                 <padding>
                                    <Insets bottom="4.0" left="4.0" right="4.0" top="4.0" />
                                 </padding>
                              </HBox>
                              <TableView fx:id="ordersTable" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                                <columns>
                                  <TableColumn prefWidth="75.0" text="Order No" />
                                  <TableColumn prefWidth="75.0" text="Date" />
                                    <TableColumn prefWidth="75.0" text="Amount" />
                                </columns>
                              </TableView>
                           </children>
                        </VBox>
                     </content>
                </Tab>
                <Tab text="Inventory">
                     <content>
                        <TableView fx:id="inventoryTable" prefHeight="200.0" prefWidth="200.0">
                          <columns>
                            <TableColumn prefWidth="75.0" text="Product" />
                            <TableColumn prefWidth="75.0" text="In Stock" />
                          </columns>
                        </TableView>
                     </content>
                </Tab>
              </tabs>
            </TabPane>
         </items>
      </SplitPane>
   </children>
</VBox>
