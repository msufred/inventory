<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="500.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <HBox alignment="CENTER_LEFT" prefWidth="200.0" spacing="4.0">
         <children>
            <Button fx:id="btnAdd" mnemonicParsing="false" styleClass="primary" text="Add Order" />
            <Button fx:id="btnPrintList" mnemonicParsing="false" text="Print List" />
         </children>
         <padding>
            <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
         </padding>
      </HBox>
      <SplitPane fx:id="splitPane" dividerPositions="0.4" VBox.vgrow="ALWAYS">
         <items>
            <TableView fx:id="ordersTable" prefHeight="200.0" prefWidth="200.0">
              <columns>
                <TableColumn fx:id="colDate" prefWidth="120.0" styleClass="table-cell-center-align" text="Date" />
                <TableColumn fx:id="colShipperName" prefWidth="120.0" styleClass="table-cell-center-align" text="Shipper Name" />
                  <TableColumn fx:id="colTotal" prefWidth="120.0" styleClass="table-cell-right-align" text="Total Amount" />
              </columns>
            </TableView>
            <VBox>
               <children>
                  <HBox styleClass="details-group">
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                     <children>
                        <Label styleClass="text-bold" text="Order Details" />
                     </children>
                     <padding>
                        <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                     </padding>
                  </HBox>
                  <TableView fx:id="orderItemsTable" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colItemName" prefWidth="120.0" text="Product" />
                        <TableColumn fx:id="colItemSupplier" prefWidth="120.0" text="Supplier" />
                        <TableColumn fx:id="colItemUnit" prefWidth="120.0" styleClass="table-cell-center-align" text="Unit" />
                        <TableColumn fx:id="colItemUnitPrice" prefWidth="120.0" styleClass="table-cell-right-align" text="Retail Price" />
                      <TableColumn fx:id="colItemQuantity" prefWidth="120.0" styleClass="table-cell-center-align" text="Quantity" />
                        <TableColumn fx:id="colItemTotal" prefWidth="120.0" styleClass="table-cell-right-align" text="Total" />
                    </columns>
                  </TableView>
                  <HBox alignment="CENTER_RIGHT" spacing="8.0" styleClass="details-group">
                     <children>
                        <Label styleClass="text-big" text="Total" />
                        <Label fx:id="lblTotal" text="P 0.00">
                           <styleClass>
                              <String fx:value="text-bold" />
                              <String fx:value="text-big" />
                           </styleClass>
                        </Label>
                     </children>
                     <padding>
                        <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                     </padding>
                  </HBox>
               </children>
            </VBox>
         </items>
      </SplitPane>
   </children>
   <stylesheets>
      <URL value="@css/bootstrap3.css" />
      <URL value="@css/styles.css" />
   </stylesheets>
</VBox>
