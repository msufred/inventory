<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="400.0" spacing="4.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1">
   <stylesheets>
      <URL value="@css/bootstrap3.css" />
      <URL value="@css/styles.css" />
   </stylesheets>
   <children>
      <Label styleClass="form-title" text="Update Status" />
      <HBox alignment="CENTER_LEFT" spacing="4.0">
         <children>
            <Label styleClass="form-label" text="Invoice No:" />
            <Label fx:id="lblTotal1" text="1001">
               <styleClass>
                  <String fx:value="form-label" />
                  <String fx:value="text-bold" />
                  <String fx:value="text-big" />
               </styleClass>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Label styleClass="form-label" text="Total" />
            <Label fx:id="lblTotal" text="P 0.00">
               <styleClass>
                  <String fx:value="form-label" />
                  <String fx:value="text-bold" />
                  <String fx:value="text-big" />
               </styleClass>
            </Label>
            <Label styleClass="form-label" text="(Cash)" />
         </children>
      </HBox>
      <HBox alignment="CENTER_LEFT" spacing="8.0">
         <children>
            <Label styleClass="form-label" text="New Status" />
            <ComboBox prefWidth="150.0" />
         </children>
      </HBox>
      <ProgressBar fx:id="progressBar" prefWidth="600.0" visible="false">
         <VBox.margin>
            <Insets />
         </VBox.margin>
      </ProgressBar>
      <HBox alignment="CENTER_RIGHT" prefWidth="200.0" spacing="5.0">
         <children>
            <Button fx:id="btnSave" defaultButton="true" mnemonicParsing="false" prefWidth="120.0" styleClass="primary" text="Save" />
            <Button fx:id="btnCancel" cancelButton="true" mnemonicParsing="false" prefWidth="120.0" text="Cancel" />
         </children>
         <VBox.margin>
            <Insets top="8.0" />
         </VBox.margin>
      </HBox>
   </children>
   <padding>
      <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
   </padding>
</VBox>
