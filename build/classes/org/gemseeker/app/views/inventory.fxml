<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="500.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <HBox prefWidth="200.0" spacing="4.0">
         <children>
            <Button fx:id="btnRefresh" mnemonicParsing="false" text="Refresh" />
            <Button fx:id="btnPrint" mnemonicParsing="false" text="Print List" />
         </children>
         <padding>
            <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
         </padding>
      </HBox>
      <TableView fx:id="itemsTable" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colName" prefWidth="120.0" text="Product Name" />
            <TableColumn fx:id="colSku" prefWidth="120.0" styleClass="table-cell-center-align" text="SKU" />
            <TableColumn fx:id="colSupplier" prefWidth="120.0" text="Supplier" />
            <TableColumn fx:id="colUnit" prefWidth="120.0" styleClass="table-cell-center-align" text="Unit" />
            <TableColumn fx:id="colUnitPrice" prefWidth="120.0" styleClass="table-cell-right-align" text="Unit Price" />
            <TableColumn fx:id="colRetailPrice" prefWidth="120.0" styleClass="table-cell-right-align" text="Retail Price" />
            <TableColumn maxWidth="10.0" prefWidth="10.0" />
            <TableColumn fx:id="colInStock" prefWidth="120.0" styleClass="table-cell-center-align" text="In Stock" />
            <TableColumn fx:id="colOrdered" prefWidth="120.0" styleClass="table-cell-center-align" text="Ordered" />
        </columns>
      </TableView>
   </children>
   <stylesheets>
      <URL value="@css/bootstrap3.css" />
      <URL value="@css/styles.css" />
   </stylesheets>
</VBox>
